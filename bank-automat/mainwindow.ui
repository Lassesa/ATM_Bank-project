  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* ===== APP BACKGROUND ===== */
#centralwidget {
    background-color: #EEF3F9;
}

/* ===== STACKED DISPLAY ===== */
#display {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffe4ec,
        stop:1 #ffffff
    );
    border-radius: 28px;
}

/* ===== TEXT ===== */
QLabel {
    color: #1E293B;
}

QLabel#labelWelcome, QLabel#labelWelcome_PIN, QLabel#labelWelcome_Main, QLabel#labelWelcome_Withdraw, QLabel#labelWelcome_Balance, QLabel#labelWelcome_Transfer, QLabel#labelWelcome_Donation, QLabel#labelWelcome_Exit, QLabel#labelWelcome_Other  {
    font-size: 40px;
    font-weight: 800;
    color: #0F172A;
}

QLabel#labelInstruction, QLabel#labelInstruction_PIN, QLabel#labelInstruction_Main, QLabel#labelInstruction_Withdraw, QLabel#labelInstruction_Balance, QLabel#labelInstruction_Balance, QLabel#labelInstruction_Transfer, QLabel#labelInstruction_Donation, QLabel#labelInstruction_Exit, QLabel#labelInstruction_Other {
    font-size: 20px;
    font-weight: 600;
    color: #475569;
}

QLabel#foundersLabel {
    font-size: 9px;
    font-weight: 600;
    color: #334155;
}

/* ===== LANGUAGE BUTTONS ===== */
QPushButton#btnLanguageEnglish,
QPushButton#btnLanguageFinnish,
QPushButton#btnLanguagePolish {
    background-color: transparent;
    color: #1E293B;
    border: 2px solid #1E293B;
    border-radius: 12px;
    padding: 6px 14px;
    font-size: 16px;
    font-weight: 700;
    min-width: 20px;
    min-height: 15px;
}

/* hover */
QPushButton#btnLanguageEnglish:hover,
QPushButton#btnLanguageFinnish:hover,
QPushButton#btnLanguagePolish:hover {
    background-color: #1E293B;
    color: white;
}

/* active (clicked) */
QPushButton#btnLanguageEnglish:checked,
QPushButton#btnLanguageFinnish:checked,
QPushButton#btnLanguagePolish:checked {
    background-color: #E83E6D;
    border: 2px solid #E83E6D;
    color: white;
}



/* ===== NUMPAD ===== */
#num_0, #num_1, #num_2, #num_3, #num_4,
#num_5, #num_6, #num_7, #num_8, #num_9,
#num_left, #num_right {
    background-color: #2F3A4D;
    color: #FFFFFF;
    border-radius: 18px;
    font-size: 26px;
    font-weight: 800;
}

/* HOVER */
#num_0:hover, #num_1:hover, #num_2:hover, #num_3:hover,
#num_4:hover, #num_5:hover, #num_6:hover,
#num_7:hover, #num_8:hover, #num_9:hover,
#num_left:hover, #num_right:hover {
    background-color: #3E4B61;
}

/* CLICK */
#num_0:pressed, #num_1:pressed, #num_2:pressed, #num_3:pressed,
#num_4:pressed, #num_5:pressed, #num_6:pressed,
#num_7:pressed, #num_8:pressed, #num_9:pressed,
#num_left:pressed, #num_right:pressed {
    background-color: #1F2937;
}

/* ===== GLOBAL BUTTON STYLE ===== */
QPushButton {
    padding: 10px;
    font-weight: bold;
    border: none;
}

/* ===== Pages Layout ===== */


#page1_Welcome,
#page2_Pin,
#page3_Main,
#page4_Withdraw,
#page5_Balance,
#page6_Transfer,
#page7_Donation,
#page8_Exit,
#page9_Other {
    background: transparent;
}



/* ===== MAIN MENU BUTTONS ===== */
#btn_main_choice_1,
#btn_main_choice_2,
#btn_main_choice_3,
#btn_main_choice_4,
#btn_main_choice_5,
#btn_main_choice_6,
#btn_main_choice_7,
#btn_main_choice_8,
#Balance_btn_choice_1 {

 background: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #F472B6,
        stop:1 #E83E6D
    );
    color: white;
    border-radius: 16px;
    padding: 16px;
    font-weight: 800;
/*
    background-color: blue;
    color: white;
    border-radius: 16px;
    padding: 16px;
    font-size: 12px;
    font-weight: 750; */
}

/* bigger (fast cash / main actions) */
#btn_main_choice_1,
#btn_main_choice_2,
#btn_main_choice_3 {
    font-size: 12px;
    font-weight: 800;
}


/* hover */
#btn_main_choice_1:hover,
#btn_main_choice_2:hover,
#btn_main_choice_3:hover,
#btn_main_choice_4:hover,
#btn_main_choice_5:hover,
#btn_main_choice_6:hover,
#btn_main_choice_7:hover,
#btn_main_choice_8:hover,
#Balance_btn_choice_1:hover{
    background-color: #1D4ED8;
}

/* pressed */
#btn_main_choice_1:pressed,
#btn_main_choice_2:pressed,
#btn_main_choice_3:pressed,
#btn_main_choice_4:pressed,
#btn_main_choice_5:pressed,
#btn_main_choice_6:pressed,
#btn_main_choice_7:pressed,
#btn_main_choice_8:pressed,
#Balance_btn_choice_1:pressed {
    background-color: #1E40AF;
}</string>
