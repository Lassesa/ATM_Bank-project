  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">/* ===== APP BACKGROUND ===== */
#centralwidget {
    background-color: #EEF3F9;
}

/* ===== STACKED DISPLAY ===== */
#display {
    background-color: transparent;
}

/* ===== MAIN CARD (THIS IS WHAT YOU SEE) ===== */
#promoCard {
    background-color: qlineargradient(
        x1:0, y1:0, x2:1, y2:1,
        stop:0 #ffffff,
        stop:1 #e0f2fe
    );
    border-radius: 28px;
    border: none;
}

/* ===== TEXT ===== */
QLabel {
    color: #1E293B;
}

QLabel#labelWelcome {
    font-size: 44px;
    font-weight: 800;
    color: #0F172A;
}

QLabel#labelInstruction {
    font-size: 20px;
    font-weight: 600;
    color: #475569;
}

QLabel#foundersLabel {
    font-size: 9px;
    font-weight: 600;
    color: #334155;
}

/* ===== LANGUAGE BUTTONS ===== */
QPushButton#btnLanguageEnglish,
QPushButton#btnLanguageFinnish,
QPushButton#btnLanguagePolish {
    background-color: transparent;
    color: #1E293B;
    border: 2px solid #1E293B;
    border-radius: 12px;
    padding: 6px 14px;
    font-size: 16px;
    font-weight: 700;
    min-width: 60px;
    min-height: 26px;
}

/* hover */
QPushButton#btnLanguageEnglish:hover,
QPushButton#btnLanguageFinnish:hover,
QPushButton#btnLanguagePolish:hover {
    background-color: #1E293B;
    color: white;
}

/* active (clicked) */
QPushButton#btnLanguageEnglish:checked,
QPushButton#btnLanguageFinnish:checked,
QPushButton#btnLanguagePolish:checked {
    background-color: #E83E6D;
    border: 2px solid #E83E6D;
    color: white;
}

/* ===== ATM SIDE BUTTONS ===== */
#button_red {
    background-color: #DC2626;
    color: white;
    border-radius: 16px;
    font-weight: 700;
}

#button_yellow {
    background-color: #F59E0B;
    color: #111827;
    border-radius: 16px;
    font-weight: 700;
}

#button_green {
    background-color: #16A34A;
    color: white;
    border-radius: 16px;
    font-weight: 700;
}

/* ===== NUMPAD ===== */
#num_0, #num_1, #num_2, #num_3, #num_4,
#num_5, #num_6, #num_7, #num_8, #num_9,
#num_left, #num_right {
    background-color: #2F3A4D;
    color: #FFFFFF;
    border-radius: 18px;
    font-size: 26px;
    font-weight: 800;
}

/* HOVER */
#num_0:hover, #num_1:hover, #num_2:hover, #num_3:hover,
#num_4:hover, #num_5:hover, #num_6:hover,
#num_7:hover, #num_8:hover, #num_9:hover,
#num_left:hover, #num_right:hover {
    background-color: #3E4B61;
}

/* CLICK */
#num_0:pressed, #num_1:pressed, #num_2:pressed, #num_3:pressed,
#num_4:pressed, #num_5:pressed, #num_6:pressed,
#num_7:pressed, #num_8:pressed, #num_9:pressed,
#num_left:pressed, #num_right:pressed {
    background-color: #1F2937;
}

/* ===== GLOBAL BUTTON STYLE ===== */
QPushButton {
    padding: 10px;
    font-weight: bold;
    border: none;
}</string>
